PORT=3000
DB_HOST=localhost
DB_PORT=0001
DB_USERNAME=postgres
DB_PASSWORD=postgres
DB_NAME=hellofutsal
DB_SYNCHRONIZE=false
DB_MIGRATIONS_RUN=true
JWT_SECRET=change-this-secret
JWT_EXPIRES_IN=1d
# Optional override for local testing. Defaults to true in non-production and false in production.
STORE_RAW_OTP=true

# When running the app in Docker Compose, use:
# DB_HOST=db
# DB_PORT=5432
