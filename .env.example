PORT=3000
DB_HOST=localhost
DB_PORT=0001
DB_USERNAME=postgres
DB_PASSWORD=postgres
DB_NAME=hellofutsal
DB_SYNCHRONIZE=false
DB_MIGRATIONS_RUN=true
JWT_SECRET=change-this-secret
JWT_EXPIRES_IN=1d
# Optional override for local testing. Defaults to true in non-production and false in production.
STORE_RAW_OTP=true

# Supabase Configuration for Image Storage
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=your-anon-key-here
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here
SUPABASE_STORAGE_BUCKET=field-images

# When running the app in Docker Compose, use:
# DB_HOST=db
# DB_PORT=5432
