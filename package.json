{
  "name": "hellofutsal",
  "version": "0.0.1",
  "private": true,
  "scripts": {
    "build": "tsc -p tsconfig.build.json",
    "start:prod": "node dist/main.js",
    "start": "node dist/main.js",
    "start:dev": "ts-node-dev --respawn --transpile-only src/main.ts",
    "db:reset:local": "sh ./scripts/reset-local-db.sh",
    "db:backup:prod": "PATH=\"/opt/homebrew/opt/libpq/bin:/usr/local/opt/libpq/bin:$PATH\" sh ./scripts/backup-prod-db.sh",
    "db:reset:prod": "PATH=\"/opt/homebrew/opt/libpq/bin:/usr/local/opt/libpq/bin:$PATH\" sh ./scripts/reset-prod-db.sh",
    "typeorm": "node -r ts-node/register ./node_modules/typeorm/cli.js -d src/data-source.ts",
    "migration:generate": "sh -c 'npm run typeorm -- migration:generate src/migrations/$1' --",
    "migration:run": "npm run typeorm -- migration:run",
    "migration:revert": "npm run typeorm -- migration:revert"
  },
  "dependencies": {
    "@nestjs/common": "^10.4.8",
    "@nestjs/config": "^3.2.3",
    "@nestjs/core": "^10.4.8",
    "@nestjs/jwt": "^10.2.0",
    "@nestjs/passport": "^10.0.3",
    "@nestjs/platform-express": "^10.4.8",
    "@nestjs/schedule": "^6.1.1",
    "@nestjs/typeorm": "^10.0.2",
    "bcryptjs": "^2.4.3",
    "class-transformer": "^0.5.1",
    "class-validator": "^0.14.1",
    "luxon": "^3.7.2",
    "passport": "^0.7.0",
    "passport-jwt": "^4.0.1",
    "pdfkit": "^0.18.0",
    "pg": "^8.13.1",
    "reflect-metadata": "^0.2.2",
    "rxjs": "^7.8.1",
    "typeorm": "^0.3.24"
  },
  "devDependencies": {
    "@types/bcryptjs": "^2.4.6",
    "@types/luxon": "^3.7.1",
    "@types/node": "^22.15.0",
    "@types/passport-jwt": "^4.0.1",
    "@types/pdfkit": "^0.17.5",
    "ts-node": "^10.9.2",
    "ts-node-dev": "^2.0.0",
    "typescript": "^5.8.3",
    "webpack-cli": "^7.0.2"
  }
}
