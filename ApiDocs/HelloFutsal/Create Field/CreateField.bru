meta {
  name: CreateField
  type: http
  seq: 1
}

post {
  url: {{development}}/fields
  body: json
  auth: bearer
}

headers {
  Content-Type: application/json
  ~Authorization: Bearer $TOKEN
}

auth:bearer {
  token: {{token}}
}

body:json {
  [
    {
      "venueName": "KC Futsal",
      "fieldName": "Kc Futsal 4A Side",
      "playerCapacity": 4,
      "address": "Balkumari Lalitpur Nepal"
    }
  ]
}
