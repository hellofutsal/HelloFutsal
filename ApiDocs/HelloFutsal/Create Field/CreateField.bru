meta {
  name: CreateField
  type: http
  seq: 1
}

post {
  url: {{development}}/fields
  body: json
  auth: bearer
}

headers {
  Content-Type: application/json
  ~Authorization: Bearer $TOKEN
}

auth:bearer {
  token: {{token}}
}

body:json {
  [
    {
      "venueName": "Ayush Field 2",
      "fieldName": "Field A - 7-a-side",
      "playerCapacity": 5,
      "address": "123 Sports Lane"
    }
  ]
}
