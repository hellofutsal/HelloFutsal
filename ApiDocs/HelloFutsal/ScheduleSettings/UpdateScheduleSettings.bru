meta {
  name: UpdateScheduleSettings
  type: http
  seq: 4
}

patch {
  url: {{development}}/fields/{{fieldId}}/schedule-settings
  body: json
  auth: bearer
}

headers {
  Content-Type: application/json
  ~Authorization: Bearer $TOKEN
}

auth:bearer {
  token: {{token}}
}

body:json {
  {
    "slotDurationMin": 60,
    "breakBetweenMin": 0,
    "basePrice": 1500,
    "operatingHours": {
      "openingTime": "06:00",
      "closingTime": "22:00"
    }
  }
}
