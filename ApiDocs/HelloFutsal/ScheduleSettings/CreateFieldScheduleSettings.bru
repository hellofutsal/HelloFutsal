meta {
  name: CreateFieldScheduleSettings
  type: http
  seq: 1
}

post {
  url: {{development}}/fields/{{fieldId}}/schedule-settings
  body: json
  auth: bearer
}

headers {
  Content-Type: application/json
  ~Authorization: Bearer $TOKEN
}

auth:bearer {
  token: {{token}}
}

body:json {
  {
    "slotDurationMin": 60,
    "breakBetweenMin": 5,
    "basePrice": 1400,
    "operatingHours": {
      "openingTime": "06:00",
      "closingTime": "14:00"
    }
  }
}
