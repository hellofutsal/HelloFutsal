{
  "name": "Create Membership Plan & Sync Membership Slots",
  "requests": [
    {
      "name": "Create Membership Plan",
      "method": "POST",
      "url": "http://localhost:3000/membership-plans",
      "headers": [
        { "name": "Content-Type", "value": "application/json" }
      ],
      "body": {
        "userName": "Jane Doe",
        "phoneNumber": "+1234567890",
        "fieldId": "<FIELD_ID>",
        "daysOfWeek": ["sunday", "friday"],
        "startTime": "14:00",
        "endTime": "15:00",
        "active": true
      },
      "description": "Creates a membership plan and immediately syncs all matching available slots for the user. Replace <USER_ID> and <FIELD_ID> with actual values."
    }
  ]
}
