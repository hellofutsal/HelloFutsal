meta {
  name: CreateFieldRuleBookSpecificSlots
  type: http
  seq: 6
}

post {
  url: {{development}}/fields/{{fieldId}}/rule-books
  body: json
  auth: bearer
}

headers {
  Content-Type: application/json
  ~Authorization: Bearer {{token}}
}

auth:bearer {
  token: {{token}}
}

body:json {
  {
