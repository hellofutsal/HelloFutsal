    "value": 700,
    "specificSlots": [
      {
        "activeDays": ["sunday", "monday", "wednesday"],
        "startTime": "06:00",
        "endTime": "07:00"
      },
      {
        "activeDays": ["sunday", "monday", "wednesday"],
        "startTime": "07:00",
        "endTime": "08:00"
      }
    ]
  }
}
